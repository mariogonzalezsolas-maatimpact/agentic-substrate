# macOS metadata
.DS_Store
*.DS_Store

# User-specific files (should not be in repo)
.claude/settings.json
.claude/settings.local.json
.claude/.circuit-breaker-state

# IDE files
.vscode/
.idea/

# Backup directories created during testing
.claude.backup-*/

# Test artifacts
test-results/

# MCP config (contains user-specific absolute paths)
.mcp.json

# Auto-generated directories (session-specific, not source code)
.claude/compact-backups/
.claude/session-data/
.claude/agent-memory/

# Runtime state
memory/errors.md
.claude/.skill-extraction-counter
